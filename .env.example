# Copy this file to .env and fill in real values before running `docker compose up`.
# .env is git-ignored; .env.example is the committed template.

# ---------------------------------------------------------------------------
# MySQL credentials — used by docker-compose.yml for the mysql service and
# to construct DATABASE_URL inside the app/ai-worker containers.
# ---------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=srx
MYSQL_USER=srx
MYSQL_PASSWORD=

# ---------------------------------------------------------------------------
# App database URL — for host-side tools (prisma studio, ad-hoc scripts).
# The compose stack overrides this internally to reach mysql:3306.
# ---------------------------------------------------------------------------
DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@localhost:3306/${MYSQL_DATABASE}"

# ---------------------------------------------------------------------------
# Gemini AI (optional — app falls back to local heuristics without a key)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_MS=60000
# GEMINI_MAX_CONCURRENT=4
# AI_COMPACT_PROMPT=0

# ---------------------------------------------------------------------------
# Redis (optional — omit to disable caching; app is fail-open)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Admin UI (/admin)
# ---------------------------------------------------------------------------
ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=   # must be ≥32 chars in production

# ---------------------------------------------------------------------------
# Door-game / MCTS tuning (all optional)
# ---------------------------------------------------------------------------
# DOOR_AI_MAX_CONCURRENT_MCTS=1
# DOOR_AI_DECIDE_BATCH_SIZE=4
# DOOR_AI_MOVE_TIMEOUT_MS=60000
# MCTS_BUDGET_MS=45000
