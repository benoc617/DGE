{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@dge/shared": ["./packages/shared/src/index.ts"],
      "@dge/shared/*": ["./packages/shared/src/*"],
      "@dge/engine": ["./packages/engine/src/index.ts"],
      "@dge/engine/redis": ["./packages/engine/src/redis.ts"],
      "@dge/engine/cache": ["./packages/engine/src/cache.ts"],
      "@dge/engine/db-context": ["./packages/engine/src/db-context.ts"],
      "@dge/engine/search": ["./packages/engine/src/search.ts"],
      "@dge/engine/*": ["./packages/engine/src/*"],
      "@dge/shell": ["./packages/shell/src/index.ts"],
      "@dge/shell/*": ["./packages/shell/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "tests/e2e",
    "packages/*/dist",
    "games/*/dist"
  ]
}
